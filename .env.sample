# Copy this file to .env and fill in the values.
# Shell environment variables take precedence over values set here.

# LLM model used for all LLM calls (LiteLLM naming convention).
# See https://docs.litellm.ai/docs/providers
LSNSTK_LLM_MODEL=gemini/gemini-2.5-flash

# Gemini Developer API key (https://aistudio.google.com/apikey).
# Required when LSNSTK_LLM_MODEL starts with "gemini/".
LSNSTK_LLM_GEMINI_API_KEY=your-gemini-api-key

# OpenRouter API key (https://openrouter.ai/settings/keys).
# Required when LSNSTK_LLM_MODEL starts with "openrouter/".
# NOTE: Stage 2 (analyse) always requires a Gemini key for video upload.
# TODO: LLMClient: Not compatible with OpenRouter.
LSNSTK_LLM_OPENROUTER_API_KEY=your-openrouter-api-key

# MLflow tracking server (start with: mlflow server --host 127.0.0.1 --port 5001).
# Port 5000 is reserved by macOS AirPlay Receiver — use 5001 or higher.
# Use a local path (e.g. mlruns) for file-based tracking without a running server.
MLFLOW_TRACKING_URI=http://localhost:5001

# Required only if the server was started with --app-name basic-auth.
# Default credentials created by MLflow on first start are admin / password.
# MLFLOW_TRACKING_USERNAME=admin
# MLFLOW_TRACKING_PASSWORD=password

# MLflow experiment name; created automatically if it does not exist.
MLFLOW_EXPERIMENT_NAME=lasagnastack
